# Set default behavior to automatically normalize line endings
* text=auto eol=lf

# -------------------------------
# Enforce LF endings for specific source files
# -------------------------------
*.sql text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.md text eol=lf

# -------------------------------
# Identify explicitly binary files
# -------------------------------
*.csv binary
*.png binary
*.pdf binary
*.jpg binary

# -------------------------------
# Ignore generated/vendored files in statistics
# -------------------------------
.venv/** linguist-vendored
data/** linguist-vendored