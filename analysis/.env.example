# -----------------------------------------------------------------------
# Olist Analytics Pipeline — Environment Configuration
# -----------------------------------------------------------------------
# Copy this file to analysis/.env and fill in your local values.
# The .env file is excluded from version control via .gitignore.
#
# All variables have sensible defaults (matching the Docker Compose defaults)
# so that the pipeline runs out-of-the-box without any changes if you are
# using the provided Dockerfile with default credentials.
# -----------------------------------------------------------------------

# PostgreSQL connection parameters
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=olist
